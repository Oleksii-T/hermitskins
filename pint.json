{
    "preset": "laravel",
    "rules": {
        "array_syntax": {
            "syntax": "short"
        },
        "blank_line_before_statement": {
            "statements": [
                "break",
                "continue",
                "declare",
                "return",
                "throw",
                "try"
            ]
        },
        "no_extra_blank_lines": {
            "tokens": [
                "attribute",
                "case",
                "continue",
                "curly_brace_block",
                "default",
                "extra",
                "parenthesis_brace_block",
                "square_brace_block",
                "switch",
                "throw",
                "use"
            ]
        },
        "single_trait_insert_per_statement": true
    }
  }